# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
._*
*.pem
Thumbs.db

# editors / IDEs
.idea/
.vscode/
.cursor/
.claude/

# logs
*.log

# OS / temp
*.tmp
*.swp

# large data dumps (don't commit BGG CSV or seed binaries)
*.csv
/data/raw/

# capacitor build artifacts
/ios/App/build/
/android/app/build/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# supabase CLI scratch state
/supabase/.temp/

# Local rulebook PDFs — used only at upload time by the admin pre-warm
# endpoint, then stored permanently on Anthropic Files API. Too big and
# license-sensitive (publishers grant personal-use only) to commit.
/game rulebooks/

# typescript
*.tsbuildinfo
next-env.d.ts
