# Anthropic — powers The Tome (wizard, strategy, teach).
ANTHROPIC_API_KEY=

# Supabase — BGG game cache today; auth + user library in PR 3.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — rate limiting for /api/ai/*.
# Auto-populated when you install the Upstash for Redis integration from the
# Vercel Marketplace (the integration uses the KV_* names for backward-compat
# with the retired Vercel KV product). Leaving these empty makes the limiter
# fail open (dev-safe).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Optional fallback for manual setups — either naming works.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
