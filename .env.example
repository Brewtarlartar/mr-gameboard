# Anthropic — powers The Tome (wizard, strategy, teach).
ANTHROPIC_API_KEY=

# Supabase — BGG game cache today; auth + user library in PR 3.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — rate limiting for /api/ai/*.
# Auto-populated when you install the Upstash for Redis integration from the
# Vercel Marketplace (the integration uses the KV_* names for backward-compat
# with the retired Vercel KV product). Leaving these empty makes the limiter
# fail open (dev-safe).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Optional fallback for manual setups — either naming works.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# BGG XML API — optional Bearer token. Leave empty if your commercial
# approval didn't issue a token (BGG's XML API works anonymously; the token
# just avoids anti-scraping rate limits on high-volume requests). If you
# receive a token from BGG later, set it here and redeploy — no code change.
BGG_API_TOKEN=
# Optional UA override; defaults to "TheTome/1.0 (mr-gameboard)".
# BGG_USER_AGENT=

# Vercel Cron authenticates /api/admin/sync-bgg via `Authorization: Bearer
# $CRON_SECRET`. Set this in Vercel env (any random string); Vercel sends it
# automatically on cron invocations. Daily 3am refresh is defined in vercel.json.
CRON_SECRET=
